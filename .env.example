POSTGRES_USER=jahon
POSTGRES_PASSWORD=replace_with_a_strong_database_password
POSTGRES_DB=jahon_xabarlari
DATABASE_URL=postgresql://jahon:replace_with_a_strong_database_password@postgres:5432/jahon_xabarlari?schema=public
# Bot FSM state and backend background jobs share Redis; production should use the private URL.
REDIS_URL=redis://redis:6379
# JWT signing keys. MUST be at least 32 random chars each and unique -- generate with
# `openssl rand -hex 32`. The API refuses to boot if these are shorter or left as a placeholder.
JWT_ACCESS_SECRET=replace_with_openssl_rand_hex_32_value_here
JWT_REFRESH_SECRET=replace_with_a_different_openssl_rand_hex_32
ADMIN_EMAIL=admin@jahonxabarlari.uz
# Existing users keep their current password when these are omitted. A fresh database requires
# distinct passwords of at least 12 characters; never commit real values here.
ADMIN_PASSWORD=
EDITOR_PASSWORD=
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=https://jahonxabarlari.uz,https://www.jahonxabarlari.uz,https://frontend-production-89aa6.up.railway.app
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=https://jahonxabarlari.uz
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Web push keys are generated once with `npx web-push generate-vapid-keys` and must remain secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@jahonxabarlari.uz
BOT_TOKEN=123456:replace_me
BOT_API_BASE=http://backend:4000/api
BOT_ADMIN_IDS=123456789,987654321
# Shared secret the bot sends (X-Bot-Secret) so /auth/telegram-login trusts it. MUST be set to
# the SAME random value (>=24 chars, `openssl rand -hex 24`) on BOTH the backend and the bot,
# otherwise Telegram admin login is refused. Without it the bot's admin actions won't work.
BOT_SERVICE_SECRET=
# Optional: enables RU/EN auto-translation of articles and the news aggregator's AI rewrite
# via OpenAI (gpt-4o-mini). Leave unset to keep translations queued as PENDING (frontend falls
# back to the UZ original) and the aggregator inert. Used by both backend and telegram-bot.
OPENAI_API_KEY=
# Optional: set to "true" only when you want the seed script to (re)create the 20 demo
# articles/ads. Leave unset in production so trashed demo content doesn't reappear on deploy.
SEED_DEMO_CONTENT=
# News aggregator: every NEWS_AGGREGATOR_INTERVAL_MINUTES, fetches configured RSS sources
# (see backend/src/services/aggregator.ts), dedupes, has OpenAI rewrite+categorize each item,
# and creates articles using the status selected in Admin panel > Agregator.
# Requires OPENAI_API_KEY. Off by default.
NEWS_AGGREGATOR_ENABLED=false
NEWS_AGGREGATOR_INTERVAL_MINUTES=5
# Publish status is stored in PostgreSQL. Its initial value is PUBLISHED.
# Optional: enables severe weather alert banners in the weather panel, proxied through the
# backend. Leave unset to silently show no alerts (the rest of the panel still works).
WEATHERAPI_API_KEY=
