generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  DELETED
}

enum AdvertisementStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum TranslationStatus {
  PENDING
  READY
  FAILED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  telegramId    String?        @unique
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  articles      Article[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
}

model Permission {
  id     String @id @default(cuid())
  key    String @unique
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
}

model AggregatorSource {
  id        String   @id @default(cuid())
  name      String
  feedUrl   String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id       String       @id @default(cuid())
  name     String
  slug     String       @unique
  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  summary         String
  content         String
  mainImage       String?
  gallery         String[]      @default([])
  categoryId      String
  extraCategoryIds String[]     @default([])
  category        Category      @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  status          ArticleStatus @default(DRAFT)
  isFeatured      Boolean       @default(false)
  isBreaking      Boolean       @default(false)
  isEditorChoice  Boolean       @default(false)
  showOnHome      Boolean       @default(true)
  showInSlider    Boolean       @default(false)
  showInSidebar   Boolean       @default(false)
  showInLatest    Boolean       @default(true)
  showInPopular   Boolean       @default(false)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  viewsCount      Int           @default(0)
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  sourceName      String?
  sourceUrl       String?       @unique
  deletedAt       DateTime?
  tags            ArticleTag[]
  comments        Comment[]
  views           ArticleView[]
  translations    ArticleTranslation[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, deletedAt, publishedAt])
  @@index([categoryId, status])
  @@index([viewsCount])
}

model ArticleTranslation {
  id             String             @id @default(cuid())
  articleId      String
  article        Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  lang           String
  title          String
  summary        String
  content        String
  slug           String
  seoTitle       String?
  seoDescription String?
  status         TranslationStatus  @default(PENDING)
  error          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([articleId, lang])
  @@index([lang, status])
}

model MediaFile {
  id        String   @id @default(cuid())
  url       String
  key       String   @unique
  mimeType  String
  size      Int
  data      Bytes?
  createdAt DateTime @default(now())
}

model Comment {
  id        String        @id @default(cuid())
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  name      String
  body      String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
}

model Advertisement {
  id        String              @id @default(cuid())
  title     String              @unique
  placement String
  imageUrl  String?
  targetUrl String?
  status    AdvertisementStatus @default(DRAFT)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
}

model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt])
}
